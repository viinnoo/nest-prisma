// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model Student {
  id        Int      @id @default(autoincrement())
  nis       String   @unique
  name      String
  email     String?  @unique
  kelas     String
  jurusan   String
  user     User?
  peminjaman Peminjaman_Buku[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Walas {
  id_walas  Int      @id @default(autoincrement())
  nama_walas String
  no_telp   String   @unique
  alamat    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Buku {
  id      Int      @id @default(autoincrement())
  judul   String
  pengarang String
  tahun   Int
  status  BookStatus @default(AVAILABLE)
  peminjaman Peminjaman_Buku[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Peminjaman_Buku {
  id_peminjaman Int @id @default(autoincrement())
  id_student Int 
  id_buku Int
  tanggal_pinjam DateTime @default(now())
  tanggal_kembali DateTime?
  pengembalian Pengembalian_Buku[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student @relation(fields: [id_student], references: [id])
  buku    Buku    @relation(fields: [id_buku], references: [id])
}

model Pengembalian_Buku {
  id_pengembalian Int @id @default(autoincrement())
  id_peminjaman Int 
  tanggal_pengembalian DateTime @default(now())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  peminjaman Peminjaman_Buku @relation(fields: [id_peminjaman], references: [id_peminjaman])
}

enum UserRole {
  ADMIN
  PETUGAS
  STUDENT
}

enum BookStatus {
  AVAILABLE
  BORROWED
}

model User {
  id Int @id @default(autoincrement())
  username String @unique
  password String
  role UserRole
  id_student Int? @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  student Student? @relation(fields: [id_student], references: [id])
}